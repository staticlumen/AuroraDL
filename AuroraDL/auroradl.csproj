<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <ApplicationIcon>auroradl.ico</ApplicationIcon>
    <AssemblyName>auroradl</AssemblyName>
    <RootNamespace>auroradl</RootNamespace>
    <Product>auroradl</Product>
    <Title>auroradl</Title>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="NAudio" Version="2.2.1" />
    <PackageReference Include="WTelegramClient" Version="4.4.2" />
  </ItemGroup>

  <ItemGroup>
    <None Update="auroradl.png">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Update="auroradl.ico">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>
</Project>
